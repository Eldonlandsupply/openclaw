# ============================================================
# EldonOpenClaw — .env.example
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── LLM PROVIDER ───────────────────────────────────────────
# Set LLM_PROVIDER to: minimax | openrouter | openai | xai | none
LLM_PROVIDER=xai

# xAI (Grok) — used when LLM_PROVIDER=xai
XAI_API_KEY=YOUR_XAI_API_KEY
OPENCLAW_CHAT_MODEL=grok-3-mini

# MiniMax — used when LLM_PROVIDER=minimax
# MINIMAX_API_KEY=YOUR_MINIMAX_KEY
# OPENAI_BASE_URL=https://api.minimax.io/v1  # optional MiniMax endpoint override

# OpenRouter — used when LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
# OPENCLAW_CHAT_MODEL=openai/gpt-4o-mini

# OpenAI direct — used when LLM_PROVIDER=openai
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# OPENCLAW_CHAT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=   # optional: override for local/self-hosted

# Embeddings (only needed if OPENCLAW_MEMORY_ENABLED=true)
OPENCLAW_EMBED_MODEL=

# ── APP ────────────────────────────────────────────────────
OPENCLAW_ENV=production
OPENCLAW_LOG_LEVEL=info

# ── CONNECTORS ─────────────────────────────────────────────
OPENCLAW_CONNECTOR_CLI=true
OPENCLAW_CONNECTOR_TELEGRAM=false
OPENCLAW_CONNECTOR_VOICE=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# ── MEMORY ─────────────────────────────────────────────────
OPENCLAW_MEMORY_ENABLED=false
OPENCLAW_VECTOR_STORE=local
OPENCLAW_VECTOR_STORE_PATH=.data/vector_store

# ── ACTION GATING ──────────────────────────────────────────
OPENCLAW_ACTION_CONFIRM=true

# ── EMAIL ──────────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFICATION_EMAIL=

# ── OUTLOOK / MICROSOFT GRAPH ──────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── ATTIO CRM ──────────────────────────────────────────────
ATTIO_API_KEY=

# ── MINIMAX ────────────────────────────────────────────────
MINIMAX_API_KEY=

# ── SUPABASE MCP ────────────────────────────────────────────
# Personal access token: https://supabase.com/dashboard/account/tokens
# NEVER use the service_role key here.
SUPABASE_ACCESS_TOKEN=
# Project ID from Dashboard → Settings → General
SUPABASE_PROJECT_REF=

# ── LOLA MEETING OPS ──────────────────────────────────────
# Pre-meeting dossiers and post-meeting notes for Teams meetings
LOLA_MEETINGS_ENABLED=false
LOLA_MEETINGS_PRIMARY_EMAIL=tynski@eldonlandsupply.com
LOLA_MEETINGS_INTERNAL_DOMAINS=eldonlandsupply.com
LOLA_MEETINGS_DOSSIER_LEAD_MINUTES=20
LOLA_MEETINGS_RETRY_INTERVAL_MINUTES=5
LOLA_MEETINGS_MAX_RETRY_MINUTES=60
LOLA_MEETINGS_POLL_INTERVAL_MINUTES=5
LOLA_MEETINGS_ORGANIZER_ONLY=false
LOLA_MEETINGS_INCLUDE_CHAT=false
LOLA_MEETINGS_INCLUDE_FILES=false
LOLA_MEETINGS_DOSSIER_INTERNAL=true
LOLA_MEETINGS_FOLLOWUP_MODE=draft_only
LOLA_MEETINGS_SKIP_DECLINED=true
LOLA_MEETINGS_ALLOWED_CATEGORIES=
LOLA_MEETINGS_BLOCKED_CATEGORIES=
