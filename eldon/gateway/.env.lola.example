# Lola WhatsApp Channel — Environment Variables
# Append to /opt/openclaw/.env

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v19.0

# ── Lola channel ─────────────────────────────────────────────────────────
ENABLE_LOLA_WHATSAPP=true
LOLA_ALLOWED_SENDERS=+1XXXXXXXXXX
LOLA_STORE_PATH=/opt/openclaw/.lola
LOLA_APPROVAL_TTL_MINUTES=60
LOLA_DEDUPE_TTL_SECONDS=600
LOLA_DRY_RUN=false

# ── LLM (inherits XAI_API_KEY or OPENROUTER_API_KEY) ─────────────────────
LOLA_LLM_MODEL=grok-3-mini

# ── Microsoft 365 / Outlook (calendar + inbox reads) ─────────────────────
OUTLOOK_TENANT_ID=5afeb96a-473a-4650-81f7-4c61f3bf3461
OUTLOOK_CLIENT_ID=a1c063c0-eefb-465d-90c2-d3eca184d33f
OUTLOOK_CLIENT_SECRET=
OUTLOOK_USER=tynski@eldonlandsupply.com

# ── Attio CRM ────────────────────────────────────────────────────────────
# (ATTIO_API_KEY likely already in .env — confirm it's set)
# ATTIO_API_KEY=

# ── Dashboard security ───────────────────────────────────────────────────
LOLA_DASHBOARD_TOKEN=
