{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EldonOpenClaw Action Schema",
  "type": "object",
  "required": ["action_id","action_name","action_category","execution_mode","status","trigger_type","owner","risk_score","enabled"],
  "properties": {
    "action_id":           {"type": "string", "pattern": "^ACT-[0-9]{4}$"},
    "action_name":         {"type": "string"},
    "action_category":     {"type": "string", "enum": ["ceo_leverage","revenue_acceleration","admin_elimination","execution_control"]},
    "action_subcategory":  {"type": "string"},
    "action_description":  {"type": "string"},
    "business_goal":       {"type": "string"},
    "expected_value_type": {"type": "string", "enum": ["revenue","time_saved","risk_reduced","relationship","cost_avoided","speed"]},
    "value_score":         {"type": "number", "minimum": 0, "maximum": 10},
    "frequency_score":     {"type": "number", "minimum": 0, "maximum": 10},
    "time_saved_score":    {"type": "number", "minimum": 0, "maximum": 10},
    "profit_impact_score": {"type": "number", "minimum": 0, "maximum": 10},
    "risk_score":          {"type": "number", "minimum": 0, "maximum": 10},
    "confidence_score":    {"type": "number", "minimum": 0, "maximum": 10},
    "composite_score":     {"type": "number"},
    "rank":                {"type": "integer"},
    "status":              {"type": "string", "enum": ["proposed","under_review","approved","enabled","paused","deprecated","rejected","archived"]},
    "execution_mode":      {"type": "string", "enum": ["auto_execute","draft_then_review","recommend_only","approval_required","manual_only"]},
    "trigger_type":        {"type": "string", "enum": ["schedule","event","threshold","request","manual"]},
    "trigger_definition":  {"type": "string"},
    "required_inputs":     {"type": "array", "items": {"type": "string"}},
    "optional_inputs":     {"type": "array", "items": {"type": "string"}},
    "system_dependencies": {"type": "array", "items": {"type": "string"}},
    "owner":               {"type": "string"},
    "approver":            {"type": "string"},
    "escalation_path":     {"type": "string"},
    "success_metric":      {"type": "string"},
    "failure_metric":      {"type": "string"},
    "last_executed_at":    {"type": ["string","null"]},
    "last_reviewed_at":    {"type": ["string","null"]},
    "review_due_date":     {"type": ["string","null"]},
    "enabled":             {"type": "boolean"},
    "notes":               {"type": "string"},
    "tags":                {"type": "array", "items": {"type": "string"}}
  }
}
