# Copy to codex_workflow/.env and adjust values.
WORKFLOW_SCHEMA_VERSION=1.0.0
WORKFLOW_NAME=codex_agentic_hardening
WORKFLOW_RUN_ID=run-20260403-0001
WORKFLOW_MODE=full

PATH_REPO_ROOT=/workspace/openclaw
PATH_WORKSPACE_ROOT=/workspace/openclaw
PATH_OUTPUT_ROOT=codex_workflow/out
PATH_LOGS_DIR=codex_workflow/out/logs

RUNTIME_LOG_LEVEL=INFO
RUNTIME_TIMEOUT_SECONDS=900
RUNTIME_REQUIRE_CLEAN_GIT=false
RUNTIME_ALLOW_NETWORK=false
RUNTIME_DRY_RUN=false

DEPENDENCIES_REQUIRED_BINARIES=python3,bash,git
ENERGY_BASIS=HHV
ENERGY_MIXED_BASIS_INPUT=false
