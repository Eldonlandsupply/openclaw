{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Workflow Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_name",
    "run_id",
    "repo_root",
    "output_dir",
    "log_level",
    "dry_run",
    "require_clean_git",
    "allow_network",
    "timeout_seconds",
    "energy_basis",
    "steps"
  ],
  "properties": {
    "workflow_name": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{3,64}$",
      "examples": ["codex_agentic_hardening"]
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[0-9]{8}-[0-9]{4}$",
      "examples": ["run-20260403-0001"]
    },
    "repo_root": {
      "type": "string",
      "minLength": 1,
      "examples": ["/workspace/openclaw"]
    },
    "input_file": {
      "type": "string",
      "default": "codex_workflow/input.json",
      "examples": ["codex_workflow/input.json"]
    },
    "output_dir": {
      "type": "string",
      "minLength": 1,
      "examples": ["codex_workflow/out"]
    },
    "log_level": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARN", "ERROR"],
      "default": "INFO"
    },
    "dry_run": {
      "type": "boolean",
      "default": false
    },
    "require_clean_git": {
      "type": "boolean",
      "default": true
    },
    "allow_network": {
      "type": "boolean",
      "default": false
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 30,
      "maximum": 7200,
      "default": 900
    },
    "energy_basis": {
      "type": "string",
      "enum": ["HHV", "LHV"]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "enabled", "command"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]{2,40}$"
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "retry_count": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3,
            "default": 0
          }
        }
      }
    }
  }
}
