{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Workflow Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow",
    "paths",
    "runtime",
    "dependencies",
    "execution",
    "verification",
    "error_policy",
    "energy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "run_id", "mode"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{3,64}$"
        },
        "run_id": {
          "type": "string",
          "pattern": "^run-[0-9]{8}-[0-9]{4}$"
        },
        "mode": {
          "type": "string",
          "enum": ["full", "validate_only"]
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_root", "workspace_root", "output_root", "logs_dir"],
      "properties": {
        "repo_root": { "type": "string", "minLength": 1 },
        "workspace_root": { "type": "string", "minLength": 1 },
        "output_root": { "type": "string", "minLength": 1 },
        "logs_dir": { "type": "string", "minLength": 1 },
        "allow_write_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": ["codex_workflow/out"]
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["log_level", "timeout_seconds", "require_clean_git", "allow_network", "dry_run"],
      "properties": {
        "log_level": {
          "type": "string",
          "enum": ["DEBUG", "INFO", "WARN", "ERROR"],
          "default": "INFO"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 7200,
          "default": 900
        },
        "require_clean_git": { "type": "boolean", "default": true },
        "allow_network": { "type": "boolean", "default": false },
        "dry_run": { "type": "boolean", "default": false }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_binaries"],
      "properties": {
        "required_binaries": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._+-]{1,64}$"
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "enabled", "command", "retry_count", "timeout_seconds"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9_-]{2,40}$" },
              "enabled": { "type": "boolean" },
              "command": { "type": "string", "minLength": 1 },
              "retry_count": { "type": "integer", "minimum": 0, "maximum": 3 },
              "timeout_seconds": { "type": "integer", "minimum": 5, "maximum": 7200 }
            }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "error_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fail_fast", "allow_silent_fallbacks"],
      "properties": {
        "fail_fast": { "type": "boolean", "const": true },
        "allow_silent_fallbacks": { "type": "boolean", "const": false }
      }
    },
    "energy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basis", "mixed_basis_input"],
      "properties": {
        "basis": { "type": "string", "enum": ["HHV", "LHV"] },
        "mixed_basis_input": { "type": "boolean", "default": false }
      }
    }
  }
}
