# OpenClaw .env example
#
# Quick start:
# 1) Copy this file to `~/.openclaw/.env` (recommended for launchd/systemd and production).
#    Repo-local `.env` is blocked by default for security-sensitive runs.
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in openclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# ngrok remote access for Raspberry Pi and edge nodes (optional)
# -----------------------------------------------------------------------------
# Local-only secret from https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=replace-with-dashboard-token
# Optional local config override (default: ~/.config/ngrok/ngrok.yml)
# NGROK_CONFIG_PATH=~/.config/ngrok/ngrok.yml
# Optional OpenClaw Gateway upstream port for HTTP tunnels
# OPENCLAW_TUNNEL_PORT=18789
# Optional reserved HTTPS domain for a stable Gateway endpoint
# OPENCLAW_NGROK_DOMAIN=https://gateway-example.ngrok.app
# Optional reserved TCP address for SSH or another raw TCP tunnel
# OPENCLAW_NGROK_TCP_ADDRESS=1.tcp.ngrok.io:12345
# Optional SSH port override if the Pi does not listen on 22
# OPENCLAW_SSH_PORT=22
# Optional local traffic policy path when using IP restrictions
# NGROK_TRAFFIC_POLICY_FILE=config/ngrok/policies/restrict-ips.template.yml

# -----------------------------------------------------------------------------
# Inbound webhooks (WhatsApp + Microsoft Graph)
# -----------------------------------------------------------------------------
# Public URL used in webhook registration (Meta + Microsoft Graph).
# WEBHOOK_BASE_URL=https://hooks.example.com
# Optional dedicated bind host/port aliases (normally reuse gateway host/port).
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=18789
# Trust X-Forwarded-* headers from a controlled reverse proxy.
# TRUST_PROXY=false
# Log webhook payload internals (masked metadata only). Keep false in production.
# LOG_WEBHOOK_PAYLOADS=false
# Webhook payload cap (bytes), default: 262144.
# WEBHOOK_MAX_BODY_BYTES=262144
# Rate limiting defaults: 120 requests per 60 seconds per route and source IP.
# RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
# RATE_LIMIT_WEBHOOK_MAX=120


# Strict WhatsApp command authorization for LOLA
# Required when LOLA_ENABLED=true. Only these E.164 numbers can run slash commands.
# Format supports optional labels with "Label|+15555550123".
# WHATSAPP_CEO_PRIMARY_NUMBER=CEO|+15555550123
# WHATSAPP_AUTHORIZED_ASSISTANTS=EA|+15555550124,Ops|+15555550125
# WHATSAPP_ALLOWED_NUMBERS=Board|+15555550126

# Meta WhatsApp webhook verification and signature secret.
# WHATSAPP_VERIFY_TOKEN=replace-with-meta-verify-token
# WHATSAPP_APP_SECRET=replace-with-meta-app-secret

# Microsoft Graph webhook validation secret and optional tenant guard.
# GRAPH_WEBHOOK_CLIENT_STATE=replace-with-graph-client-state
# GRAPH_ALLOWED_TENANTS=00000000-0000-0000-0000-000000000000


# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890
# TELEGRAM_MODE=polling
# TELEGRAM_WEBHOOK_URL=https://hooks.example.com/telegram-webhook
# TELEGRAM_WEBHOOK_SECRET=replace-with-long-random-secret
# LOLA_TELEGRAM_ENABLED=false
# LOLA_TELEGRAM_DEFAULT_ROUTE=lola
# LOLA_TELEGRAM_APPROVAL_REQUIRED_ACTIONS=email_send,calendar_mutation,repo_mutation
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# LOLA phase 1 (read-only scaffold)
# -----------------------------------------------------------------------------
# LOLA_ENABLED=true
# LOLA_DRY_RUN=true
# LOLA_APPROVAL_MODE=required
# LOLA_EXECUTIVE_NAME=Executive Placeholder
# LOLA_TIMEZONE=America/New_York
# LOLA_WRITE_ENABLED=false
# LOLA_WRITE_INBOX=false
# LOLA_WRITE_MEMORY=false
# LOLA_WRITE_CALENDAR=false
# LOLA_WRITE_BRIEFING=false
# LOLA_WRITE_FOLLOWTHROUGH=false
# LOLA_WRITE_AUDIT=false
# LOLA_EXTERNAL_ACTIONS_ENABLED=false
# LOLA_EXTERNAL_ACTIONS_DEFAULT_PROVIDER=Outlook
# M365_TENANT_ID=00000000-0000-0000-0000-000000000000
# M365_CLIENT_ID=00000000-0000-0000-0000-000000000000
# M365_CLIENT_SECRET=
# M365_USER_EMAIL=ceo@example.com
# M365_SCOPES=Mail.Read Mail.ReadWrite Mail.Send Calendars.Read Contacts.Read
# M365_TOKEN_CACHE_FILE=~/.openclaw/credentials/m365/token-cache.enc.json
# LOLA_M365_TENANT_ID=00000000-0000-0000-0000-000000000000
# LOLA_M365_CLIENT_ID=00000000-0000-0000-0000-000000000000
# LOLA_M365_CLIENT_SECRET=
# LOLA_M365_MAILBOX_UPN=tynski@eldonlandsupply.com
# LOLA_M365_EXPECTED_UPN=tynski@eldonlandsupply.com
# LOLA_M365_EXPECTED_TENANT_ID=00000000-0000-0000-0000-000000000000
# LOLA_M365_DELEGATED_SCOPES=Mail.Read Mail.ReadWrite Mail.Send Calendars.Read Contacts.Read
# LOLA_M365_APPLICATION_ROLES=Mail.Read Mail.ReadWrite Mail.Send Calendars.Read Contacts.Read Chat.Read.All Chat.ReadWrite.All ChannelMessage.Read.Group ChannelMessage.Send OnlineMeetings.Read.All OnlineMeetingTranscript.Read.All
# LOLA_M365_TEAMS_BOT_SCOPES=ChannelMessage.Read.Group ChannelMessage.Send Chat.ReadBasic
# LOLA_M365_GRAPH_ACCESS_TOKEN=
