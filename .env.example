# LOLA_WRITE_INBOX=false
# LOLA_WRITE_MEMORY=false
# LOLA_WRITE_CALENDAR=false
# LOLA_WRITE_BRIEFING=false
# LOLA_WRITE_FOLLOWTHROUGH=false
# LOLA_WRITE_AUDIT=false
